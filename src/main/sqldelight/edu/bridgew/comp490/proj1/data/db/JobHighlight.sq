CREATE TABLE IF NOT EXISTS JobHighlightDAO (
    title TEXT,
    items TEXT NOT NULL,
    jobId TEXT NOT NULL,
    FOREIGN KEY (jobId) REFERENCES JobDAO(jobId)
);

getHighlights:
SELECT title, items
FROM JobHighlightDAO
WHERE :jobId = jobId;

insertHighlight:
INSERT INTO JobHighlightDAO(title, items, jobId)
VALUES (?, ?, ?);