CREATE TABLE IF NOT EXISTS LinkDAO (
    link TEXT NOT NULL,
    `text` TEXT NOT NULL,
    jobId TEXT NOT NULL,
    PRIMARY KEY (link, jobId),
    FOREIGN KEY (jobId) REFERENCES JobDAO(jobId)
);

getLinks:
SELECT link, `text`
FROM LinkDAO
WHERE :jobId = jobId;

insertLink:
INSERT OR REPLACE INTO LinkDAO
VALUES (?, ?, ?);
